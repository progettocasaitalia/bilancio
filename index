        h1 { font-size: 2.2em; margin-bottom: 10px; color: #2d3436; }
        .sub { color: #636e72; margin-bottom: 30px; }

        /* LA TORTA IN PURO CSS (Niente JS esterno) */
        .pie-chart {
            width: 350px;
            height: 350px;
            margin: auto;
            border-radius: 50%;
            background: conic-gradient(
                #ff7675 0% 35.2%,    /* Previdenza */
                #55efc4 35.2% 49%,   /* Sanità */
                #74b9ff 49% 57.1%,   /* Istruzione */
                #a29bfe 57.1% 64.6%, /* Interessi */
                #fab1a0 64.6% 68.8%, /* Difesa */
                #dfe6e9 68.8% 100%   /* Altro */
            );
            border: 8px solid white;
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
            position: relative;
            transition: transform 0.3s;
            cursor: pointer;
        }

        .pie-chart:hover { transform: scale(1.05) rotate(2deg); }

        /* Legenda */
        .legend { display: flex; flex-wrap: wrap; justify-content: center; margin-top: 30px; gap: 15px; }
        .item { display: flex; align-items: center; font-size: 0.9em; }
        .dot { width: 15px; height: 15px; border-radius: 3px; margin-right: 8px; }

        .btn-sanita {
            margin-top: 25px;
            padding: 12px 25px;
            background: #55efc4;
            border: none;
            border-radius: 30px;
            color: #1d3932;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(85, 239, 196, 0.4);
        }
    </style>
</head>
