        body { font-family: 'Segoe UI', sans-serif; background: #f8f9fa; margin: 0; display: flex; flex-direction: column; align-items: center; }
        header { width: 100%; background: white; padding: 15px 0; text-align: center; border-bottom: 1px solid #ddd; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .nav-sim { font-size: 0.8em; word-spacing: 20px; color: #555; margin-top: 10px; text-transform: uppercase; }

